{
  "name": "@medullaflow/ribosome",
  "version": "0.1.3",
  "description": "The MCP package manager: declare language runtimes and MCP servers in one manifest, resolved together and pinned into a reproducible lockfile. Embeddable in workflow orchestrators.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ribosome": "dist/cli.js"
  },
  "license": "MPL-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "prepare": "bun scripts/setup-git-hooks.js",
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck:test": "tsc --noEmit -p tsconfig.check.json",
    "test": "bun run build && node scripts/run-tests.js",
    "compile": "bun build --compile bin/ribosome.ts --outfile dist/ribosome",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "spdx:check": "bun scripts/check-spdx-headers.js --all",
    "spdx:fix": "bun scripts/check-spdx-headers.js --fix",
    "check": "bun scripts/check.js",
    "check:staged": "bun scripts/check.js --staged",
    "check:architecture": "bun scripts/check-architecture.js",
    "mutation-test": "scripts/mutation-test.sh"
  },
  "dependencies": {
    "@medullaflow/ribosome-schema": "^0.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@stryker-mutator/core": "^9.6.1",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "typescript": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/medullaflow/ribosome"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "package-manager",
    "mcp-server",
    "mcp-registry",
    "dependency-manager",
    "lockfile",
    "devtools"
  ]
}
