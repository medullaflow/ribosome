{
  "name": "@medullaflow/ribosome",
  "version": "0.1.0",
  "description": "Standalone dependency resolver: tool/runtime versions via mise-en-place, MCP servers via the MCP Registry. Designed for embedding in workflow orchestrators.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "prepare": "bun scripts/setup-git-hooks.js",
    "build": "tsc",
    "test": "bun run build && bun test",
    "compile": "bun build --compile src/index.ts --outfile dist/ribosome-lib-smoke",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "spdx:check": "bun scripts/check-spdx-headers.js --all",
    "spdx:fix": "bun scripts/check-spdx-headers.js --fix"
  },
  "dependencies": {
    "@medullaflow/ribosome-schema": "file:../ribosome-schema/bindings/typescript"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/medullaflow/ribosome"
  },
  "keywords": [
    "dependency-resolution",
    "mise",
    "mcp",
    "mcp-registry",
    "workflow",
    "devtools"
  ]
}
