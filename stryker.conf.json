{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "bun run build && bun test test/materializer.test.ts test/resolve-mcp-server.test.ts test/file-registry.test.ts test/lockfile-writer.test.ts"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "src/orchestrator/materializer.ts",
    "src/orchestrator/resolve-mcp-server.ts",
    "src/orchestrator/runtime-mapping.ts",
    "src/orchestrator/lockfile-writer.ts",
    "src/adapters/mcp-registry/file-registry.ts"
  ],
  "reporters": ["clear-text", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "inPlace": true,
  "concurrency": 2,
  "timeoutMS": 30000,
  "tempDirName": ".stryker-tmp"
}
